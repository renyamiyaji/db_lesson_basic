-- Q4: Update NULL department_id
UPDATE people
SET department_id = (
  SELECT department_id FROM departments WHERE name = '営業' LIMIT 1
)
WHERE department_id IS NULL;

-- Q5: Male names and ages in descending order of age
SELECT name, age
FROM people
WHERE gender = 1
ORDER BY age DESC;

